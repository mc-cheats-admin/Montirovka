{
  "name": "gaming",
  "display_name": "Gaming / Highlight",
  "target_fps": 120,
  "interpolation_engine": "rife",
  "enable_motion_blur": true,
  "highlight_detection": {
    "enabled": true,
    "audio_energy_threshold": 0.7,
    "min_gap_seconds": 2.0
  },
  "crosshair_tracking": {
    "enabled": true,
    "roi_size": 200,
    "template_match_threshold": 0.6,
    "crop_scale": 0.7,
    "zoom_in_scale": 1.3,
    "zoom_in_duration_seconds": 0.5,
    "zoom_hold_seconds": 2.0,
    "easing": "ease_in_out"
  },
  "cutting": {
    "remove_silence": true,
    "remove_dead_segments": true,
    "aggressiveness": 0.7
  },
  "audio": {
    "noise_reduction": true,
    "highpass_hz": 80,
    "presence_boost_db": 3,
    "presence_band_hz": 3500,
    "mud_cut_db": -2,
    "mud_band_hz": 300,
    "compressor_ratio": 4.0,
    "compressor_threshold_db": -18,
    "target_lufs": -14
  },
  "transitions": {
    "type": "whip",
    "duration_ms": 180
  }
}